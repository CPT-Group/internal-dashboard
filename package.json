{
  "name": "internal-dashboard",
  "version": "0.1.58",
  "private": true,
  "scripts": {
    "predev": "node scripts/cursor-analytics/summarize-cursor-exports.mjs --dir data/cursor-analytics/csv --out data/cursor-analytics/cursor-analytics-summary.json",
    "dev": "node scripts/generate-conference-slides.js && node scripts/generate-julies-background-slides.js && node scripts/generate-jackies-background-slides.js && next dev -p 3333",
    "prebuild": "node scripts/cursor-analytics/summarize-cursor-exports.mjs --dir data/cursor-analytics/csv --out data/cursor-analytics/cursor-analytics-summary.json",
    "build": "node scripts/generate-conference-slides.js && node scripts/generate-julies-background-slides.js && node scripts/generate-jackies-background-slides.js && next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test:sql": "node scripts/test-sql-connections.cjs",
    "test:github-deploy-tokens": "node scripts/test-github-deploy-tokens.mjs",
    "test:impediment-analytics": "node scripts/test-impediment-analytics.mjs",
    "test:operational-board-analytics": "node scripts/test-operational-board-analytics.mjs",
    "verify:operational-board": "node scripts/verify-operational-board.mjs",
    "test:deploy-lane-mapping": "node scripts/test-deploy-lane-mapping.mjs",
    "verify:deploy-lane-mapping": "node scripts/verify-deploy-lane-mapping.mjs",
    "test:cursor-usage-event-repo": "tsx scripts/cursor-analytics/verify-usage-event-repo.ts",
    "cursor-analytics:reconcile-day": "tsx scripts/cursor-analytics/reconcile-usage-events-day.ts",
    "cursor-analytics:sync-billing": "tsx scripts/cursor-analytics/sync-billing.ts",
    "test:cursor-billing-store": "tsx scripts/cursor-analytics/test-cursor-billing-store.ts",
    "test:cursor-analytics-auth": "tsx scripts/test-cursor-analytics-auth.ts",
    "cursor-analytics:summarize": "node scripts/cursor-analytics/summarize-cursor-exports.mjs --dir data/cursor-analytics/csv",
    "cursor-analytics:regen": "node scripts/cursor-analytics/summarize-cursor-exports.mjs --dir data/cursor-analytics/csv --out data/cursor-analytics/cursor-analytics-summary.json"
  },
  "dependencies": {
    "@azure/msal-browser": "^5.15.0",
    "@azure/msal-react": "^5.5.0",
    "@tsparticles/engine": "^4.2.1",
    "@tsparticles/react": "^4.2.1",
    "@tsparticles/slim": "^4.2.1",
    "chart.js": "^4.5.1",
    "chartjs-adapter-date-fns": "^3.0.0",
    "chartjs-plugin-datalabels": "^2.2.0",
    "date-fns": "^4.1.0",
    "dotenv": "^17.4.0",
    "jose": "^6.2.3",
    "mssql": "^12.2.1",
    "next": "^16.2.3",
    "primeflex": "^4.0.0",
    "primeicons": "^7.0.0",
    "primereact": "^10.9.7",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.71.1",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@types/mssql": "^9.1.11",
    "@types/node": "^25",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "eslint": "^9",
    "eslint-config-next": "^16.2.3",
    "eslint-plugin-react-hooks": "^7.1.1",
    "sass": "^1.97.3",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "typescript-eslint": "^8.56.0"
  },
  "overrides": {
    "minimatch": "^10.2.1"
  }
}
